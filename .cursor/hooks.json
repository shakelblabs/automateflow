{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": "node .cursor/hooks/check-docs-index.js",
        "timeout": 5
      }
    ],
    "postToolUse": [
      {
        "command": "node .cursor/hooks/check-docs-index.js",
        "matcher": "Delete",
        "timeout": 5
      }
    ]
  }
}
